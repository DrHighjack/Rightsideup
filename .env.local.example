DATABASE_URL="file:./prisma/dev.db"
NEXTAUTH_SECRET="your-random-secret-here-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_GOOGLE_MAPS_KEY="your-google-maps-api-key"
RESEND_API_KEY="your-resend-api-key"
RESEND_FROM_EMAIL="orders@example.com"

# FluidPay payments
# Secret API key from the FluidPay dashboard (server only — never NEXT_PUBLIC)
FLUIDPAY_API_KEY=""
# Public tokenizer key for the hosted card fields in the browser
NEXT_PUBLIC_FLUIDPAY_PUBLIC_KEY=""
# Defaults to https://app.fluidpay.com — set to https://sandbox.fluidpay.com to test
FLUIDPAY_BASE_URL=""
NEXT_PUBLIC_FLUIDPAY_BASE_URL=""
# Signature key shown when you create the webhook in FluidPay (recommended)
FLUIDPAY_WEBHOOK_SECRET=""
